{
  "luau-lsp.platform.type": "roblox",
  "luau-lsp.sourcemap.enabled": false,
  "luau-lsp.types.definitionFiles": {
    "@roblox": "https://luau-lsp.pages.dev/type-definitions/globalTypes.PluginSecurity.d.luau"
  },
  "luau-lsp.fflags.enableNewSolver": true,
  "luau-lsp.fflags.override": {
    "LuauExportValueSyntax": "True",
    "LuauExportValueTypecheck": "True",
    "LuauAutocompleteExport": "True",
    "LuauConst": "True"
  },
  "git.ignoredRepositories": [
    "vendor/cargo",
    "vendor/luau",
    "vendor/luau-lsp",
    "vendor/lute",
    "vendor/tint",
    "vendor/pesde",
    "vendor/darklua",
    "vendor/rojo"
  ],
  "search.exclude": {
    "**/vendor": true,
    "**/node_modules": true,
    "**/luau_packages": true,
    "**/Packages": true,
    "**/.git": true,
    "**/.tmp": true,
    "**/dist": true,
    "**/.cache": true,
    "**/.codex": true,
    "**/.vscode": true,
    "*.html": true
  }
}
