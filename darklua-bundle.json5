{
  generator: "retain_lines",
  rules: [],
  lua_extension: "luau",
  bundle: {
    require_mode: {
      name: "luau",
      aliases: {
        "@core": "./core",
        "@lib": "./lib",
        "@runtimes": "./runtimes",
        "@packages": "./luau_packages",
        "@lutest": ".",
      },
      use_luau_configuration: false,
    },
    excludes: ["@std/**", "@lute/**", "@batteries/**", "@lint/**"],
  },
}
