{
  "name": "lutest",
  "version": "0.1.0",
  "description": "Lutest is a test runner for Luau code, with a focus on `lute` and Roblox runtimes.",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "prepare": "husky",
    "format": "mise exec -- stylua .",
    "lint": "mise exec -- lute lint .",
    "release:build": "mise exec -- lute run scripts/release.luau",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cayasde/lutest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/cayasde/lutest/issues"
  },
  "homepage": "https://github.com/cayasde/lutest#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{luau,lua}": [
      "mise exec -- stylua",
      "mise exec -- lute lint"
    ]
  }
}
