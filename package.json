{
  "name": "lutest",
  "version": "0.7.1",
  "description": "Lutest is a test runner for Luau code, with a focus on `lute` and Roblox runtimes.",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "prepare": "husky",
    "format": "mise run format",
    "format:check": "mise run format-check",
    "typecheck": "mise run typecheck",
    "check": "mise run check",
    "release:build": "mise exec -- lute run scripts/release.luau",
    "release:version": "changeset version && node scripts/sync-version.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lutest-dev/lutest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lutest-dev/lutest/issues"
  },
  "homepage": "https://github.com/lutest-dev/lutest#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{luau,lua}": [
      "mise exec -- stylua"
    ]
  }
}
